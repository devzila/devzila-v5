# DevZila — Apache config for clean (extensionless) URLs

RewriteEngine On

# If the site is served from a subdirectory, set this to that path, e.g. /myapp/
# RewriteBase /

# Use index.php as the directory index so "/" serves the homepage
DirectoryIndex index.php

# Pass HTTP Basic Auth credentials through to PHP (needed by the admin panel
# on some CGI/FastCGI setups).
CGIPassAuth On
RewriteCond %{HTTP:Authorization} .+
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# ── Security: block direct web access to sensitive files ──
<FilesMatch "\.(sql|md)$">
  Require all denied
</FilesMatch>
<Files "config.php">
  Require all denied
</Files>
<Files "config.sample.php">
  Require all denied
</Files>
# Never serve the include partials or library files directly
RewriteRule ^(partials|lib)/ - [F,L]

# ── Clean URLs ──

# 1) Redirect "/index" or "/index.php" to "/"
RewriteCond %{THE_REQUEST} \s/+index(\.php)?[\s?] [NC]
RewriteRule ^ /? [R=301,L]

# 2) Redirect any external "/page.php" request to the extensionless "/page"
RewriteCond %{THE_REQUEST} \s/+([^.\s?]+)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 3) Pretty blog post URLs: /blog/{slug} -> blog-post.php?slug={slug}
RewriteRule ^blog/([A-Za-z0-9_-]+)/?$ blog-post.php?slug=$1 [L,QSA]

# 4) Internally map an extensionless URL to its .php file (no redirect, so POST works)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.+?)/?$ $1.php [L]
